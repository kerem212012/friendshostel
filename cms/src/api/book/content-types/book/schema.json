{
  "kind": "collectionType",
  "collectionName": "books",
  "info": {
    "singularName": "book",
    "pluralName": "books",
    "displayName": "Book"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "firstname": {
      "type": "string",
      "required": true
    },
    "email": {
      "type": "email",
      "required": true
    },
    "from": {
      "type": "date",
      "required": true
    },
    "to": {
      "type": "date",
      "required": true
    },
    "phone": {
      "type": "string",
      "required": true
    },
    "priceType": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "breakfast",
        "without_breakfast"
      ]
    },
    "room": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::room.room"
    },
    "message": {
      "type": "text"
    },
    "isPaid": {
      "type": "boolean",
      "default": false
    },
    "adults": {
      "type": "integer",
      "min": 0
    },
    "externalReserveID": {
      "type": "biginteger"
    },
    "isCancelReserve": {
      "type": "boolean",
      "default": false
    },
    "lastname": {
      "type": "string"
    }
  }
}
