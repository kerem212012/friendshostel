{
  "kind": "collectionType",
  "collectionName": "rooms",
  "info": {
    "singularName": "room",
    "pluralName": "rooms",
    "displayName": "Room"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "siteTitle": {
      "type": "string"
    },
    "photos": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "externalID": {
      "type": "biginteger",
      "private": true
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": false
    },
    "data": {
      "type": "json"
    },
    "seo": {
      "type": "component",
      "component": "shared.seo",
      "repeatable": false
    },
    "basePrices": {
      "type": "json"
    },
    "prices": {
      "type": "json"
    }
  }
}
